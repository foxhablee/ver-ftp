{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "src/env.d.ts",
    "electron.vite.config.*",
    "src/preload/**/*",
    "src/shared/**/*",
    "src/backend/**/*.ipc-model.*",
  ],
  "exclude": [],
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["electron-vite/node"]
  }
}
